#!/usr/bin/env sh
set -e

echo "pre-commit: typecheck..."
npm run typecheck

echo "pre-commit: tests..."
npm test

if command -v gitleaks >/dev/null 2>&1; then
  echo "pre-commit: secret scan..."
  gitleaks protect --staged --redact --no-git
else
  echo "pre-commit: gitleaks not installed — skipping local scan (CI will catch leaks)."
  echo "  Install: brew install gitleaks"
fi
