# Copy this to .env and fill in your keys

# ---------------------------------------------------------------------------
# LLM Providers
# ---------------------------------------------------------------------------

# Required: Groq API key — get one at https://console.groq.com/keys
GROQ_API_KEY=gsk_...

# Optional: OpenRouter is used as fallback if Groq fails
# Get a key at https://openrouter.ai/keys
# OPENROUTER_API_KEY=sk-or-v1-...

# ---------------------------------------------------------------------------
# Google SSO (OAuth 2.0)
# ---------------------------------------------------------------------------
# 1. Go to https://console.cloud.google.com/apis/credentials
# 2. Click "Create Credentials" → "OAuth 2.0 Client ID"
# 3. Choose Application type: "Web application"
# 4. Under "Authorised redirect URIs" add:
#      https://<your-site>.netlify.app/api/auth/google/callback
#      http://localhost:8888/api/auth/google/callback   (for local dev)
# 5. Copy the Client ID and Client Secret below

GOOGLE_CLIENT_ID=<your-numeric-id>.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=<your-client-secret>

# The URI Google will redirect back to after the user approves the login.
# Must exactly match one of the URIs you added in the Google Console above.
GOOGLE_REDIRECT_URI=https://<your-site>.netlify.app/api/auth/google/callback

# Secret used to sign session JWTs (HS256).
# Generate a strong random value with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-a-64-byte-random-hex-string

# ---------------------------------------------------------------------------
# Razorpay Payments
# ---------------------------------------------------------------------------
# 1. Sign up / log in at https://dashboard.razorpay.com/
# 2. Go to Settings → API Keys
# 3. Generate keys (use "Test Mode" keys during development — prefix: rzp_test_)
# 4. Switch to "Live Mode" keys (prefix: rzp_live_) before going to production

# Key ID is public (safe to pass to the frontend Razorpay checkout script)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxxxxxx

# Key Secret is private — never expose this to the client
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
